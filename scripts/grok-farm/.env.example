# Grok HTTP farm (in-tree: scripts/grok-farm)
# Copy to .env and fill. Boterdrop solver stays EXTERNAL.

# Boterdrop Turnstile/cf_clearance solver (REQUIRED, external service)
BOTERDROP_URL=http://127.0.0.1:8000

# Digitalin tempmail API
GROK_EMAIL_MODE=tempmail
GROK_TEMPMAIL_API_URL=https://digitalin-id-mail-api.halimcakep45.workers.dev
GROK_TEMPMAIL_API_KEY=dim_xxxxxxxx

# Password for farmed xAI accounts
GROK_PASSWORD=ChangeMe123!

# Batch defaults (dashboard Farm overrides via CLI -n -c)
GROK_MAX_ACCOUNTS=5
GROK_CONCURRENT=1
GROK_SPAWN_DELAY=2
GROK_OTP_TIMEOUT=90

# Proxies (recommended when concurrent > 1)
# GROK_PROXY_FILE=./proxies.txt

# Results stay under this package
# GROK_RESULTS_DIR=./results

# Etteum push (injected by dashboard farm job; set for CLI runs)
# ETTEUM_URL=http://127.0.0.1:1930
# ETTEUM_API_KEY=same-as-etteum-API_KEY
# GROK_PUSH_ETTEUM=true
# GROK_PUSH_MODE=per_success
