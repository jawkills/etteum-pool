# CodeBuddy HTTP farm (in-tree: scripts/codebuddy-farm)
# Copy to .env and fill. HME service + captcha solver stay EXTERNAL.

# iCloud HME (xiaozhou26-style) — REQUIRED
MAIL_BACKEND=icloud_hme
ICLOUD_HME_URL=http://127.0.0.1:8081
ICLOUD_HME_ACCOUNT=acc_main
# Override if your HME fork uses different paths:
# ICLOUD_HME_GENERATE_PATH=/api/hme/generate
# ICLOUD_HME_INBOX_PATH=/api/inbox

# DataImpulse sticky residential — REQUIRED (1 account = 1 sessid)
DI_LOGIN=
DI_PASSWORD=
DI_HOST=gw.dataimpulse.com:823
DI_COUNTRIES=sg,us,de,nl,id,th,vn,jp
DI_SESSTTL=15

# DataDome captcha solver (waguri) — REQUIRED, same egress IP as farm sticky proxy
CAPTCHA_SOLVER_URL=http://127.0.0.1:8877

# GitHub warm (light)
GH_WARMUP=1
GH_WARM_STARS=1
GH_WARM_FOLLOWS=0
GH_WARM_FORKS=0

# CodeBuddy GLOBAL
CODEBUDDY_BASE=https://www.codebuddy.ai
CODEBUDDY_HTTP_ONLY=true

# Batch defaults (dashboard overrides via -n -c)
CODEBUDDY_MAX_ACCOUNTS=1
CODEBUDDY_CONCURRENT=1
CODEBUDDY_SPAWN_DELAY=4

# Etteum push (injected by dashboard; set for CLI runs)
# ETTEUM_URL=http://127.0.0.1:1930
# ETTEUM_API_KEY=same-as-etteum-API_KEY
# CODEBUDDY_PUSH_ETTEUM=true
# CODEBUDDY_PUSH_MODE=per_success
