{
  "name": "etteum-pool",
  "version": "1.0.0",
  "description": "AI Proxy Pool for Multiple Providers (Kiro, CodeBuddy, Codex, Canva, Qoder, GitLab Duo, YouMind) — PRIVATE",
  "type": "module",
  "scripts": {
    "start": "bun scripts/production.ts",
    "start:fast": "bun scripts/production.ts --skip-build",
    "dev": "bun scripts/start.ts",
    "build": "cd dashboard && bun run build",
    "migrate": "bun src/db/migrate.ts",
    "doctor": "bun scripts/doctor.ts",
    "setup": "bash install.sh",
    "setup:win": "powershell -ExecutionPolicy Bypass -File install.ps1",
    "preflight": "bun scripts/preflight.ts"
  },
  "dependencies": {
    "cbor-x": "^1.6.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.17",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "better-sqlite3": "^12.11.1",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
