# Core ports
PORT=1930
DASHBOARD_PORT=1931

# API key (clients send as Authorization: Bearer <key>)
API_KEY=pool-proxy-secret-key

# Database (SQLite)
DATABASE_PATH=./data/poolprox3.db

# Token encryption key (32 hex chars). install.sh / install.ps1 generate one for you.
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6

# Auth bot (Python + Playwright/Camoufox).
# Defaults below assume the in-tree venv at scripts/auth/.venv created by the installer.
# Script path relative to AUTH_SCRIPT_CWD (basename preferred).
# Do NOT use ./scripts/auth/login.py here — spawn cwd is already scripts/auth.
AUTH_SCRIPT_PATH=login.py
# Python path — leave empty for auto-detection (recommended).
# The server auto-detects the correct venv path for your OS:
#   Linux/macOS: scripts/auth/.venv/bin/python
#   Windows:     scripts/auth/.venv/Scripts/python.exe
PYTHON_PATH=
AUTH_SCRIPT_CWD=./scripts/auth

# Outbound proxy for the auth bot (optional, e.g. http://user:pass@host:port)
PROXY_URL=

# Browser engine for auth: camoufox (anti-detect, default) | chromium
BROWSER_ENGINE=camoufox
HEADLESS=true

# Captcha solver (optional)
CAPTCHA_SERVICE=none
CAPTCHA_API_KEY=

# Kiro Pro auto-upgrade (uses VCC pool)
KIRO_PRO_UPGRADE=false

# Grok CLI HTTP farm (dashboard Accounts → Grok CLI → Farm)
# Default path is ALWAYS in-tree: ./scripts/grok-farm (do not point outside the repo).
# Installer creates scripts/grok-farm/.venv + copies .env.example → .env
# Grok Build/CLI provider (subscription oauth via cli-chat-proxy)
# Optional overrides (GROK_* preferred; GROK_CLI_* still accepted as fallback):
# GROK_UPSTREAM_BASE=https://cli-chat-proxy.grok.com/v1
# GROK_TOKEN_URL=https://auth.x.ai/oauth2/token
# GROK_CLIENT_ID=b1a00492-073a-47ea-816f-4c329264a828
# GROK_CLIENT_IDENTIFIER=grok-shell
# GROK_CLIENT_VERSION=0.2.99
# GROK_REFRESH_LEAD_SEC=2700
# GROK_IMAGE_TIMEOUT_MS=180000
#
# Grok HTTP farm — secrets live in scripts/grok-farm/.env (gitignored):
# GROK_TEMPMAIL_API_KEY, BOTERDROP_URL
# GROK_FARM_DIR=./scripts/grok-farm
# GROK_FARM_PYTHON=py
# GROK_FARM_PYTHON_ARGS=-3
